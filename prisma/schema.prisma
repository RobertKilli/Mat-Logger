// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum UserGoal {
  CUT
  MAINTAIN
  BULK
}

enum Language {
  NB
  EN
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  display_name      String?          @default("Pilot")
  theme_color       String?          @default("#00FF41")
  language          Language         @default(NB)
  weight            Float?
  protein_goal      Int?             @default(0)
  calorie_goal      Int?             @default(2500)
  goal              UserGoal         @default(MAINTAIN)
  subscription_tier SubscriptionTier @default(FREE)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  food_logs         FoodLog[]
  workout_logs      WorkoutLog[]
  food_items        FoodItem[]
  biometric_logs    BiometricLog[]
  integrations      Integration[]

  @@map("users")
}

model Integration {
  id            String   @id @default(uuid())
  user_id       String
  provider      String   // e.g. "GARMIN", "APPLE_HEALTH"
  access_token  String
  refresh_token String?
  expires_at    DateTime?
  last_synced   DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, provider])
  @@map("integrations")
}

model BiometricLog {
  id               String   @id @default(uuid())
  user_id          String
  type             String   // SLEEP_SCORE, RESTING_HR, STRESS_LEVEL, BODY_BATTERY
  value            Float
  unit             String?
  source           String?  // e.g. "GARMIN_FENIX_7"
  logged_at        DateTime @default(now())
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, type, logged_at])
  @@map("biometric_logs")
}

model ModelVersion {
  id           String       @id @default(uuid())
  version_name String
  is_active    Boolean      @default(true)
  created_at   DateTime     @default(now())
  food_logs    FoodLog[]
  workout_logs WorkoutLog[]

  @@map("model_versions")
}

enum FoodCategory {
  MEAT
  FISH
  FRUIT
  VEGETABLE
  DAIRY
  GRAIN
  SUPPLEMENT
  OTHER
}

enum BaseUnit {
  GRAM
  ML
  UNIT
}

model FoodItem {
  id               String       @id @default(uuid())
  user_id          String?      // Nullable for global items
  name             String
  brand            String?
  source           String       @default("INTERNAL") // e.g., "INTERNAL", "Open Food Facts"
  externalId       String?      // ID from source
  barcode          String?
  category         FoodCategory @default(OTHER)
  image_url        String?
  
  // Flexible logging fields
  baseAmount       Float        @default(100)
  baseUnit         BaseUnit     @default(GRAM)
  gramsPerUnit     Float?       // Weight in grams for one unit (e.g. 60 for an egg)
  
  servingSize      Float?       // Weight in grams for one serving
  servingUnit      String?      // Name of serving (e.g. "portion", "cup")

  // Nutrients (usually per 100g or per baseAmount)
  proteinPer100g   Float
  carbsPer100g     Float
  fatPer100g       Float
  caloriesPer100g  Float
  
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  food_logs        FoodLog[]

  user User? @relation(fields: [user_id], references: [id])

  @@index([name])
  @@index([barcode])
  @@map("food_items")
}

enum InputMode {
  GRAMS
  UNITS
  SERVING
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model FoodLog {
  id                 String    @id @default(uuid())
  user_id            String
  food_item_id       String
  model_version_id   String
  
  // Logging inputs
  inputMode          InputMode @default(GRAMS)
  inputAmount        Float
  
  // Calculated actuals
  calculatedGrams    Float
  calculatedProtein  Float
  calculatedCarbs    Float
  calculatedFat      Float
  calculatedCalories Float
  
  mealType           MealType?
  notes              String?
  
  logged_at          DateTime  @default(now())
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  user          User         @relation(fields: [user_id], references: [id])
  food_item     FoodItem     @relation(fields: [food_item_id], references: [id])
  model_version ModelVersion @relation(fields: [model_version_id], references: [id])

  @@map("food_logs")
}

enum TrainingCategory {
  PUSH
  PULL
  LEGS
}

model Exercise {
  id               String           @id @default(uuid())
  name             String           @unique
  category         TrainingCategory
  description      String?
  instructions     String?
  image_url        String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  workout_exercises WorkoutExercise[]

  @@map("exercises")
}

model WorkoutLog {
  id                       String           @id @default(uuid())
  user_id                  String
  category                 TrainingCategory
  duration_minutes         Int
  intensity                Int
  predicted_fatigue_at_log Int?
  subjective_fatigue       Int?
  subjective_notes         String?
  model_version_id         String
  logged_at                DateTime         @default(now())

  user              User              @relation(fields: [user_id], references: [id])
  model_version     ModelVersion      @relation(fields: [model_version_id], references: [id])
  workout_exercises WorkoutExercise[]

  @@map("workout_logs")
}

model WorkoutExercise {
  id             String     @id @default(uuid())
  workout_log_id String
  exercise_id    String
  sets           Int
  reps           Int
  weight         Float?
  notes          String?
  order          Int        @default(0)

  workout_log WorkoutLog @relation(fields: [workout_log_id], references: [id], onDelete: Cascade)
  exercise    Exercise   @relation(fields: [exercise_id], references: [id])

  @@map("workout_exercises")
}
