// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  weight       Float?
  protein_goal Int?         @default(0)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  food_logs    FoodLog[]
  workout_logs WorkoutLog[]
  food_items   FoodItem[]

  @@map("users")
}

model ModelVersion {
  id           String       @id @default(uuid())
  version_name String
  is_active    Boolean      @default(true)
  created_at   DateTime     @default(now())
  food_logs    FoodLog[]
  workout_logs WorkoutLog[]

  @@map("model_versions")
}

enum FoodCategory {
  MEAT
  FISH
  FRUIT
  VEGETABLE
  DAIRY
  GRAIN
  SUPPLEMENT
  OTHER
}

enum BaseUnit {
  GRAM
  ML
  UNIT
}

model FoodItem {
  id             String       @id @default(uuid())
  user_id        String?      // Nullable for global items
  name           String
  brand          String?
  category       FoodCategory @default(OTHER)
  image_url      String?
  
  // New flexible logging fields
  baseAmount     Float        @default(100)
  baseUnit       BaseUnit     @default(GRAM)
  gramsPerUnit   Float?       // Weight in grams for one unit (e.g. 60 for an egg)
  
  // Nutrients per baseAmount
  protein        Float
  carbs          Float
  fat            Float
  calories       Float
  
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  food_logs      FoodLog[]

  user User? @relation(fields: [user_id], references: [id])

  @@index([name])
  @@map("food_items")
}

enum InputMode {
  GRAMS
  UNITS
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model FoodLog {
  id                 String    @id @default(uuid())
  user_id            String
  food_item_id       String
  model_version_id   String
  
  // Logging inputs
  inputMode          InputMode @default(GRAMS)
  inputAmount        Float
  
  // Calculated actuals
  calculatedGrams    Float
  calculatedProtein  Float
  calculatedCarbs    Float
  calculatedFat      Float
  calculatedCalories Float
  
  mealType           MealType?
  notes              String?
  
  logged_at          DateTime  @default(now())
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  user          User         @relation(fields: [user_id], references: [id])
  food_item     FoodItem     @relation(fields: [food_item_id], references: [id])
  model_version ModelVersion @relation(fields: [model_version_id], references: [id])

  @@map("food_logs")
}

enum TrainingCategory {
  PUSH
  PULL
  LEGS
}

model WorkoutLog {
  id                       String           @id @default(uuid())
  user_id                  String
  category                 TrainingCategory
  duration_minutes         Int
  intensity                Int
  predicted_fatigue_at_log Int?
  subjective_fatigue       Int?
  subjective_notes         String?
  model_version_id         String
  logged_at                DateTime         @default(now())

  user          User         @relation(fields: [user_id], references: [id])
  model_version ModelVersion @relation(fields: [model_version_id], references: [id])

  @@map("workout_logs")
}
